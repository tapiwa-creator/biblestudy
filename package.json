{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "concurrently \"npm run tailwind:watch\" \"react-scripts start\"",
    "build": "npm run tailwind:build && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "tailwind:watch": "tailwindcss -i ./src/index.css -o ./src/tailwind.output.css --watch",
    "tailwind:build": "tailwindcss -i ./src/index.css -o ./src/tailwind.output.css"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.1"
  }
}
